# Supabase configuration
# Required for server-side API routes
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required for client-safe configuration and browser usage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: protect admin CSV export and dashboard routes
ADMIN_DASHBOARD_TOKEN=

# For Vercel, add the same values in Project Settings -> Environment Variables,
# then trigger a redeploy.
